<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Thương hiệu (Brands)</h2>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addBrandModal">
      + Thêm Thương Hiệu
    </button>
  </div>
  <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
      <strong>Lỗi xóa dữ liệu:</strong> <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <div class="table-responsive shadow-sm">
    <table class="table table-hover table-bordered bg-white align-middle">
      <thead class="table-dark">
        <tr>
          <th width="10%">STT</th>
          <th width="60%">Tên Thương Hiệu</th>
          <th width="30%" class="text-center">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (brands && brands.length > 0) { %>
          <% brands.forEach(function(brand, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td class="fw-bold"><%= brand.brandName %></td>
              <td class="text-center">
                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#editBrandModal<%= brand._id %>">Sửa</button>
                
                <form action="/brands/delete/<%= brand._id %>" method="POST" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa thương hiệu này không?');">
                  <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                </form>
              </td>
            </tr>

            <div class="modal fade" id="editBrandModal<%= brand._id %>" tabindex="-1">
              <div class="modal-dialog">
                <div class="modal-content">
                  <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Sửa Thương Hiệu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <form action="/brands/edit/<%= brand._id %>" method="POST">
                    <div class="modal-body text-start">
                      <div class="mb-3">
                        <label>Tên Thương Hiệu</label>
                        <input type="text" name="brandName" class="form-control" value="<%= brand.brandName %>" required>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="submit" class="btn btn-primary">Lưu Thay Đổi</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>

          <% }); %>
        <% } else { %>
          <tr><td colspan="3" class="text-center text-muted py-4">Chưa có thương hiệu nào.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="addBrandModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title">Thêm Thương Hiệu Mới</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/brands" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label>Tên Thương Hiệu</label>
            <input type="text" name="brandName" class="form-control" required placeholder="Nhập tên thương hiệu...">
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-success">Thêm Mới</button>
        </div>
      </form>
    </div>
  </div>
</div>