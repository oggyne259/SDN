<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách Thành viên (Hệ thống)</h2>
    <span class="badge bg-danger p-2">Quyền Quản Trị Viên</span>
  </div>

  <div class="table-responsive shadow-sm">
    <table class="table table-hover table-bordered bg-white align-middle">
      <thead class="table-dark">
        <tr>
          <th>STT</th>
          <th>Họ và Tên</th>
          <th>Email</th>
          <th>Năm sinh</th>
          <th>Giới tính</th>
          <th>Vai trò</th>
        </tr>
      </thead>
      <tbody>
        <% if (members && members.length > 0) { %>
          <% members.forEach(function(member, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td class="fw-bold"><%= member.name %></td>
              <td><%= member.email %></td>
              <td><%= member.YOB %></td>
              <td><%= member.gender ? 'Nam' : 'Nữ' %></td>
              <td>
                <% if (member.isAdmin) { %>
                  <span class="badge bg-danger">Admin</span>
                <% } else { %>
                  <span class="badge bg-primary">Member</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center text-muted py-4">Chưa có thành viên nào trong hệ thống.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>