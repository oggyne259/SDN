<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h2 class="mb-1">Danh sách Thành viên</h2>
    <p class="text-muted mb-0">Giám sát người dùng và phân quyền trong hệ thống.</p>
  </div>
  <span class="badge badge-soft px-3 py-2">Chế độ Quản trị viên</span>
</div>

<div class="summary-grid mb-4">
  <div class="summary-card p-3">
    <p class="text-muted mb-1">Tổng thành viên</p>
    <h4 class="mb-0"><%= members ? members.length : 0 %></h4>
  </div>
  <div class="summary-card p-3">
    <p class="text-muted mb-1">Admin</p>
    <h4 class="mb-0"><%= members ? members.filter(m => m.isAdmin).length : 0 %></h4>
  </div>
  <div class="summary-card p-3">
    <p class="text-muted mb-1">Member</p>
    <h4 class="mb-0"><%= members ? members.filter(m => !m.isAdmin).length : 0 %></h4>
  </div>
</div>

<div class="table-wrap p-2">
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>STT</th>
          <th>Họ và Tên</th>
          <th>Email</th>
          <th>Năm sinh</th>
          <th>Giới tính</th>
          <th>Vai trò</th>
        </tr>
      </thead>
      <tbody>
        <% if (members && members.length > 0) { %>
          <% members.forEach(function(member, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td class="fw-semibold"><%= member.name %></td>
              <td><%= member.email %></td>
              <td><%= member.YOB %></td>
              <td><%= member.gender ? 'Nam' : 'Nữ' %></td>
              <td>
                <% if (member.isAdmin) { %>
                  <span class="badge bg-danger">Admin</span>
                <% } else { %>
                  <span class="badge bg-secondary">Member</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" class="text-center text-muted py-4">Chưa có thành viên nào trong hệ thống.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>                                         