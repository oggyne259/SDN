<hr class="mt-5 mb-4">
  
  <div class="row">
    <div class="col-md-12">
      <h4 class="mb-4">Đánh giá sản phẩm (<%= perfume.comments.length %>)</h4>
      
      <% if (perfume.comments && perfume.comments.length > 0) { %>
        <% perfume.comments.forEach(function(comment) { %>
          <div class="card mb-3 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <h6 class="fw-bold text-primary"><%= comment.author ? comment.author.name : 'Người dùng ẩn danh' %></h6>
                <span class="badge bg-warning text-dark"><%= comment.rating %> / 3 Sao</span>
              </div>
              <p class="mt-2 mb-0"><%= comment.content %></p>
              <small class="text-muted"><%= new Date(comment.createdAt).toLocaleString('vi-VN') %></small>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!</p>
      <% } %>

      <div class="card mt-4 bg-light">
        <div class="card-body">
          <% if (!currentUserId) { %>
            <div class="text-center">
              <p>Bạn cần đăng nhập để gửi bình luận.</p>
              <a href="/auth/login" class="btn btn-primary">Đăng nhập ngay</a>
            </div>
          <% } else { %>
            <% 
              // Kiểm tra xem user hiện tại đã bình luận chưa
              const hasCommented = perfume.comments.some(c => c.author && c.author._id.toString() === currentUserId);
            %>
            
            <% if (hasCommented) { %>
              <div class="alert alert-info text-center mb-0">
                Bạn đã gửi đánh giá cho sản phẩm này rồi! Cảm ơn bạn.
              </div>
            <% } else { %>
              <h5 class="mb-3">Gửi đánh giá của bạn</h5>
              <form action="/perfumes/<%= perfume._id %>/comments" method="POST">
                <div class="mb-3">
                  <label>Chất lượng (Từ 1 - 3 sao):</label>
                  <select name="rating" class="form-select w-25" required>
                    <option value="3">3 Sao - Tuyệt vời</option>
                    <option value="2">2 Sao - Khá tốt</option>
                    <option value="1">1 Sao - Bình thường</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label>Nội dung bình luận:</label>
                  <textarea name="content" class="form-control" rows="3" required placeholder="Nhập cảm nhận của bạn về sản phẩm..."></textarea>
                </div>
                <button type="submit" class="btn btn-success">Gửi Đánh Giá</button>
              </form>
            <% } %>
          <% } %>
        </div>
      </div>
      
    </div>
  </div>