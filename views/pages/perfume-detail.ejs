<div class="container section-block">
  <div class="row g-4">
    <div class="col-lg-5">
      <div class="card overflow-hidden">
        <img src="<%= perfume.uri %>" class="w-100" style="height: 520px; object-fit: cover;" alt="<%= perfume.perfumeName %>">
      </div>
    </div>
    <div class="col-lg-7">
      <div class="card p-4 h-100">
        <p class="text-muted mb-2"><%= perfume.brand ? perfume.brand.brandName : 'N/A' %></p>
        <h2 class="mb-3"><%= perfume.perfumeName %></h2>
        <div class="d-flex gap-2 flex-wrap mb-3">
          <span class="badge-lux"><%= perfume.targetAudience %></span>
          <span class="badge-lux"><%= perfume.concentration %></span>
          <span class="badge-lux"><%= perfume.volume %> ml</span>
        </div>
        <p class="text-muted"><%= perfume.description %></p>
        <p class="mb-4"><strong>Thành phần:</strong> <%= perfume.ingredients %></p>
        <div class="d-flex align-items-center justify-content-between mt-auto">
          <span class="product-price">$<%= perfume.price %></span>
          <a href="/" class="btn btn-outline-primary">Quay lại danh sách</a>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-5">
    <h4 class="mb-3">Đánh giá sản phẩm (<%= perfume.comments.length %>)</h4>

    <% if (perfume.comments && perfume.comments.length > 0) { %>
      <div class="vstack gap-3">
        <% perfume.comments.forEach(function(comment) { %>
          <div class="comment-card p-3">
            <div class="d-flex justify-content-between mb-2">
              <strong><%= comment.author ? comment.author.name : 'Người dùng ẩn danh' %></strong>
              <span class="badge bg-warning text-dark"><%= comment.rating %> / 3</span>
            </div>
            <p class="mb-1"><%= comment.content %></p>
            <small class="text-muted"><%= new Date(comment.createdAt).toLocaleString('vi-VN') %></small>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-muted">Chưa có đánh giá nào cho sản phẩm này.</p>
    <% } %>

    <div class="card mt-4 p-3 p-md-4">
      <% if (!currentUserId) { %>
        <p class="mb-3">Bạn cần đăng nhập để gửi đánh giá.</p>
        <a href="/auth/login" class="btn btn-brand">Đăng nhập ngay</a>
      <% } else { %>
        <% const hasCommented = perfume.comments.some(c => c.author && c.author._id.toString() === currentUserId); %>
        <% if (hasCommented) { %>
          <div class="alert alert-info mb-0">Bạn đã gửi đánh giá cho sản phẩm này rồi.</div>
        <% } else { %>
          <h5 class="mb-3">Gửi đánh giá của bạn</h5>
          <form action="/perfumes/<%= perfume._id %>/comments" method="POST">
            <div class="row g-3">
              <div class="col-md-3">
                <label class="form-label">Số sao</label>
                <select name="rating" class="form-select" required>
                  <option value="3">3 - Tuyệt vời</option>
                  <option value="2">2 - Khá tốt</option>
                  <option value="1">1 - Bình thường</option>
                </select>
              </div>  
              <div class="col-md-9">
                <label class="form-label">Nội dung</label>
                <textarea name="content" class="form-control" rows="3" required placeholder="Chia sẻ cảm nhận của bạn..."></textarea>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-brand">Gửi đánh giá</button>
              </div>
            </div>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>
</div>                  