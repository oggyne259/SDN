<div class="container section-block">
  <div class="hero-card p-4 p-md-5 mb-4">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <h1 class="mb-3">Khám phá bộ sưu tập nước hoa cao cấp</h1>
        <p class="text-muted mb-0">Tìm mùi hương phù hợp với cá tính của bạn: tinh tế, cuốn hút và khác biệt.</p>
      </div>
      <div class="col-lg-4">
        <form action="/" method="GET" class="row g-2">
          <div class="col-12">
            <input type="text" name="perfumeName" class="form-control" placeholder="Tìm theo tên nước hoa..." value="<%= searchName %>">
          </div>
          <div class="col-12">
            <select name="brand" class="form-select">
              <option value="">Tất cả thương hiệu</option>
              <% brands.forEach(function(b) { %>
                <option value="<%= b._id %>" <%= selectedBrand == b._id.toString() ? 'selected' : '' %>><%= b.brandName %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-12 d-grid">
            <button type="submit" class="btn btn-brand">Tìm kiếm</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <% if (perfumes && perfumes.length > 0) { %>
      <% perfumes.forEach(function(perfume) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card product-card h-100">
            <img class="product-image" src="<%= perfume.uri %>" alt="<%= perfume.perfumeName %>">
            <div class="card-body d-flex flex-column">
              <small class="text-muted"><%= perfume.brand ? perfume.brand.brandName : 'N/A' %></small>
              <h5 class="mt-2"><%= perfume.perfumeName %></h5>
              <div class="my-3 d-flex gap-2 flex-wrap">
                <span class="badge-lux"><%= perfume.targetAudience %></span>
                <span class="badge-lux"><%= perfume.concentration %></span>
              </div>
              <div class="mt-auto d-flex justify-content-between align-items-center">
                <span class="product-price">$<%= perfume.price %></span>
                <a href="/perfumes/<%= perfume._id %>" class="btn btn-outline-primary btn-sm">Chi tiết</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <p class="text-muted mb-0">Không tìm thấy sản phẩm phù hợp với bộ lọc hiện tại.</p>
      </div>
    <% } %>
  </div>

  <% if (totalPages > 1) { %>
    <nav class="mt-5" aria-label="Page navigation">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/?page=<%= currentPage - 1 %>&perfumeName=<%= searchName %>&brand=<%= selectedBrand %>">&laquo;</a>
        </li>
        <% for(let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= currentPage === i ? 'active' : '' %>">
            <a class="page-link" href="/?page=<%= i %>&perfumeName=<%= searchName %>&brand=<%= selectedBrand %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="/?page=<%= currentPage + 1 %>&perfumeName=<%= searchName %>&brand=<%= selectedBrand %>">&raquo;</a>          
        </li> 
      </ul>
    </nav>
  <% } %>
</div>                           