<div class="container section-block">
  <div class="row justify-content-center g-4">
    <div class="col-lg-7">
      <h2 class="mb-3">Hồ sơ cá nhân</h2>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

      <div class="card p-4 mb-4">
        <h5 class="mb-3">Cập nhật thông tin</h5>
        <form action="/members/profile" method="POST" class="row g-3">
          <div class="col-12">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" value="<%= member.email %>" disabled>
          </div>
          <div class="col-12">
            <label class="form-label">Họ và tên</label>
            <input type="text" name="name" class="form-control" value="<%= member.name %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Năm sinh</label>
            <input type="number" name="YOB" class="form-control" value="<%= member.YOB %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Giới tính</label>
            <select name="gender" class="form-select" required>
              <option value="true" <%= member.gender === true ? 'selected' : '' %>>Nam</option>
              <option value="false" <%= member.gender === false ? 'selected' : '' %>>Nữ</option>
            </select>
          </div>
          <div class="col-12"><button type="submit" class="btn btn-brand">Lưu thay đổi</button></div>
        </form>
      </div>

      <div class="card p-4">
        <h5 class="mb-3">Đổi mật khẩu</h5>
        <form action="/members/change-password" method="POST" class="row g-3">
          <div class="col-12">
            <label class="form-label">Mật khẩu cũ</label>
            <input type="password" name="oldPassword" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Mật khẩu mới</label>
            <input type="password" name="newPassword" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Xác nhận mật khẩu mới</label>
            <input type="password" name="confirmPassword" class="form-control" required>
          </div>
          <div class="col-12"><button type="submit" class="btn btn-outline-primary">Đổi mật khẩu</button></div>
        </form>
      </div>
    </div>
  </div>
</div>