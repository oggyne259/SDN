<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- locals.title || 'Admin Dashboard' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/admin.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg admin-topbar sticky-top">
    <div class="container-fluid px-3 px-md-4">
      <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-light d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar" aria-controls="adminSidebar">
          <i class="bi bi-list"></i>
        </button>
        <a class="navbar-brand d-flex align-items-center gap-2 mb-0" href="/admin/perfumes">
          <i class="bi bi-gem"></i>
          <span>Scent House Admin</span>
        </a>
      </div>
      <div class="d-flex align-items-center gap-2 gap-md-3">
        <a class="topbar-link" href="/"><i class="bi bi-house"></i> Trang chủ</a>
        <a class="topbar-link" href="/members/profile"><i class="bi bi-person-circle"></i> Hồ sơ</a>
        <a class="btn btn-sm btn-outline-light" href="/auth/logout">Đăng xuất</a>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row g-0">
      <aside class="col-lg-2 admin-sidebar d-none d-lg-block">
        <div class="p-3 p-lg-4">
          <p class="sidebar-label mb-2">Điều hướng</p>
          <nav class="nav flex-column gap-2">
            <a class="nav-link <%= locals.title && locals.title.includes('Nước Hoa') ? 'active' : '' %>" href="/admin/perfumes"><i class="bi bi-bag"></i> Quản lý nước hoa</a>
            <a class="nav-link <%= locals.title && locals.title.includes('Thương hiệu') ? 'active' : '' %>" href="/brands"><i class="bi bi-tags"></i> Quản lý thương hiệu</a>
            <a class="nav-link <%= locals.title && locals.title.includes('Thành viên') ? 'active' : '' %>" href="/collectors"><i class="bi bi-people"></i> Thành viên</a>
          </nav>
        </div>
      </aside>

      <div class="offcanvas offcanvas-start admin-offcanvas" tabindex="-1" id="adminSidebar" aria-labelledby="adminSidebarLabel">
        <div class="offcanvas-header border-bottom border-secondary-subtle">
          <h5 class="offcanvas-title" id="adminSidebarLabel">Điều hướng</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
          <nav class="nav flex-column gap-2">
            <a class="nav-link <%= locals.title && locals.title.includes('Nước Hoa') ? 'active' : '' %>" href="/admin/perfumes"><i class="bi bi-bag"></i> Quản lý nước hoa</a>
            <a class="nav-link <%= locals.title && locals.title.includes('Thương hiệu') ? 'active' : '' %>" href="/brands"><i class="bi bi-tags"></i> Quản lý thương hiệu</a>
            <a class="nav-link <%= locals.title && locals.title.includes('Thành viên') ? 'active' : '' %>" href="/collectors"><i class="bi bi-people"></i> Thành viên</a>
          </nav>
        </div>
      </div>
      
      <section class="col-lg-10 admin-content">
        <div class="p-3 p-md-4 p-xl-5 page-shell">
          <%- body %>
        </div>
      </section>
    </div>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>