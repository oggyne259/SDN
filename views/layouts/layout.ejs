<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- locals.title || 'Perfume Shop' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg app-navbar sticky-top">
    <div class="container py-2">
      <a class="navbar-brand" href="/">Scent House</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
          <% if (isAuthenticated) { %>
            <% if (isAdmin) { %>
              <li class="nav-item">
                <a class="nav-link" href="/admin/perfumes">Quản lý Shop</a>
              </li>
            <% } %>
            <li class="nav-item">
              <a class="nav-link" href="/members/profile">Hồ sơ</a>
            </li>
            <li class="nav-item">
              <a class="btn btn-sm btn-outline-light mt-2 mt-lg-0" href="/auth/logout">Đăng xuất</a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="btn btn-sm btn-brand mt-2 mt-lg-0" href="/auth/login">Đăng nhập / Đăng ký</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="pb-5">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 